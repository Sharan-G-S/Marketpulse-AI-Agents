# Environment Configuration
# Copy this file to .env and fill in your API keys

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose: "openai" or "google"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o-mini

# Google Gemini (used when LLM_PROVIDER=google)
# GOOGLE_API_KEY=your-google-api-key-here
# LLM_MODEL=gemini-1.5-flash

# ── News API ──────────────────────────────────────────────────────────────────
# Get your free key at: https://newsapi.org/register
# Leave empty to use built-in mock data (for development/testing)
NEWSAPI_KEY=your-newsapi-key-here

# ── Stock Data ────────────────────────────────────────────────────────────────
# yfinance is free and requires no API key
DEFAULT_PERIOD=1mo          # Options: 1d, 5d, 1mo, 3mo, 6mo, 1y, 2y, 5y
DEFAULT_INTERVAL=1d         # Options: 1m, 5m, 15m, 1h, 1d, 1wk, 1mo
NEWS_MAX_ARTICLES=10

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./memory/faiss_index
EMBEDDING_MODEL=text-embedding-3-small

# ── Reports ───────────────────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
